SregistryPath = "HKLM: \50FTWARE\Policies \Microsoft\Windows \EventLog\Application"
SvalueName = "MaxSize"

# Check If the registry path exists, if not create it
if (-not (Test-Path sregistryPath)) {
New-Item -Path $registryPath -Force

# Set the MaxSize value
